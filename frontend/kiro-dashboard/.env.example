# Privy app ID — get it at https://dashboard.privy.io
VITE_PRIVY_APP_ID=

VITE_STELLAR_NETWORK=TESTNET
VITE_HORIZON_URL=https://horizon-testnet.stellar.org
# Asset code and issuer address for the TESOURO token on Stellar
VITE_TESOURO_CODE=TESOURO
VITE_TESOURO_ISSUER=

ETHERFUSE_BASE_URL=https://api.sand.etherfuse.com
ETHERFUSE_API_KEY=

# When "true", shows the "Pular aprovação (sandbox)" button in the KYC modals.
# Keep "false" in production — the backend also gates the sandbox-approve route
# on the base URL, but this flag hides the UI entry point.
VITE_ETHERFUSE_SANDBOX=true
