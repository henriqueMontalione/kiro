# HTTP server
PORT=8000

# Postgres — must match docker-compose.yml values when running locally
DATABASE_URL=postgres://kiro:kiro@db:5432/kiro?sslmode=disable

# Privy app ID — same one the frontend uses (VITE_PRIVY_APP_ID).
# The backend verifies JWTs against Privy's JWKS at:
#   https://auth.privy.io/api/v1/apps/{PRIVY_APP_ID}/.well-known/jwks.json
PRIVY_APP_ID=

# CORS — comma-separated list of allowed Origins. Localhost in dev,
# production domain(s) in prod.
ALLOWED_ORIGINS=http://localhost:5173
